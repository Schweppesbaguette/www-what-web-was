{
  "name": "www-what-web-was",
  "version": "1.0.0",
  "description": "WWW What Web Was",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --arm64 --x64"
  },
  "build": {
    "appId": "com.whatwebwas.www",
    "productName": "WhatWebWas",
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "title": "WhatWebWas"
    },
    "files": ["main.js", "preload.js", "src/**/*"]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  }
}
