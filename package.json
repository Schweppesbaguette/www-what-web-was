{
  "name": "www-what-web-was",
  "version": "1.0.0",
  "description": "WWW What Web Was",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --arm64 --x64"
  },
  "build": {
    "appId": "com.whatwebwas.www",
    "productName": "WhatWebWas",
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build/icon.icns",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "WhatWebWas uses your camera for video chat.",
        "NSMicrophoneUsageDescription": "WhatWebWas uses your microphone for video chat."
      },
      "target": [
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "entitlements.mac.plist"
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  }
}
