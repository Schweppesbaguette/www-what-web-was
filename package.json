{
  "name": "www-what-web-was",
  "version": "1.0.0",
  "description": "WWW — What Web Was: Y2K retro browser experience",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --arm64 --x64"
  },
  "build": {
    "appId": "com.whatwebwas.www",
    "productName": "WWW - What Web Was",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "dmg": {
      "title": "WWW - What Web Was",
      "contents": [
        { "x": 150, "y": 185, "type": "file" },
        { "x": 390, "y": 185, "type": "link", "path": "/Applications" }
      ]
    },
    "files": ["main.js", "preload.js", "src/**/*"]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
